# --- Server ---
HOST=127.0.0.1
PORT=8765

# --- Claude API ---
ANTHROPIC_API_KEY=sk-ant-...
# Any current Claude model. sonnet is a good latency/cost fit for this chat loop.
CLAUDE_MODEL=claude-sonnet-4-6

# --- Heatmiser NeoHub ---
# Set NEOHUB_MOCK=1 to run with fake zones (no hub needed) while you try it out.
NEOHUB_MOCK=1

# Real hub settings (used when NEOHUB_MOCK is not 1):
NEOHUB_HOST=192.168.1.50
# Legacy hubs: port 4242, no token.
# Gen 2 / Mini hubs: port 4243 + an API token (generate one in the neoApp:
#   Settings -> API / "Connections" -> create token).
NEOHUB_PORT=4242
NEOHUB_TOKEN=
